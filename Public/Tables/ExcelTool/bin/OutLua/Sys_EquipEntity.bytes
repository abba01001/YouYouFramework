Sys_EquipEntity = { Id = 0, EquipId = 0, Type = 0, Stage = 0, Name = "" }

Sys_EquipEntity.__index = Sys_EquipEntity;

function Sys_EquipEntity.New(Id, EquipId, Type, Stage, Name)
    local self = { };
    setmetatable(self, Sys_EquipEntity);

    self.Id = Id;
    self.EquipId = EquipId;
    self.Type = Type;
    self.Stage = Stage;
    self.Name = Name;

    return self;
end