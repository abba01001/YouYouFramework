<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools"
          package="com.DefaultCompany.YFYouYou">

    <!-- 常用权限 -->
    <!-- 权限：网络访问 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 权限：电话相关 -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- 权限：Wi-Fi 相关 -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- 权限：外部存储 -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <!-- 权限：位置访问 -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- 权限：应用安装 -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- 权限：振动 -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- 这里可以加入你以后需要的其他权限，例如第三方SDK的权限 -->

    <!-- 声明应用相关 -->
    <application
            android:allowBackup="true"
            android:label="@string/app_name"
            android:supportsRtl="true"
            android:theme="@style/Theme.AppCompat.NoActionBar">

        <!-- Unity 主活动 -->
        <activity
                android:name="com.framework.app.CustomUnityActivity"
                android:exported="true">

            <!-- 设置该 Activity 为启动项 -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

            <!-- Unity 配置 -->
            <meta-data
                    android:name="unityplayer.UnityActivity"
                    android:value="true"/>
        </activity>

        <!-- 这里可以添加其它的 activity 或服务，未来扩展 SDK 用 -->

        <!-- 例如：第三方 SDK 的服务或广播接收器 -->
        <!-- <service android:name="com.thirdparty.sdk.ServiceName"/> -->
        <!-- <receiver android:name="com.thirdparty.sdk.ReceiverName"/> -->

    </application>
</manifest>